# PostgreSQL — Vercel Postgres o cualquier instancia PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# MongoDB — MongoDB Atlas recomendado para Vercel
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/scrapper?retryWrites=true&w=majority"

# Redis — Upstash recomendado para Vercel (serverless-compatible)
REDIS_URL="rediss://default:PASSWORD@HOST:PORT"

# SMTP — para notificaciones por email cuando se detectan cambios
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tu@correo.com"
SMTP_PASS="tu-app-password"
SMTP_FROM="Scrapper <tu@correo.com>"

# Logging (opcional) — 'info' por defecto, opciones: trace | debug | info | warn | error
LOG_LEVEL="info"
