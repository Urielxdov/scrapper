# PostgreSQL — Neon (neon.tech) recomendado para Vercel
# Obtener en: Neon dashboard → Connection string
DATABASE_URL="postgresql://USERNAME:PASSWORD@ep-xxx-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# MongoDB — MongoDB Atlas (cloud.mongodb.com)
# Obtener en: Cluster → Connect → Drivers → Node.js
# Reemplazar USERNAME, PASSWORD y usar "scrapper" como nombre de DB
MONGODB_URI="mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/scrapper?retryWrites=true&w=majority"

# Redis — Upstash (console.upstash.com) — único compatible con Vercel serverless
# Obtener en: Database → Details → Redis URL (formato rediss://)
REDIS_URL="rediss://default:PASSWORD@xxx-xxx.upstash.io:6379"

# SMTP — notificaciones por email al detectar cambios
# Gmail: requiere "App Password" (no tu contraseña normal)
# Activar en: Google Account → Security → 2FA → App passwords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tu@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
SMTP_FROM="Scrapper <tu@gmail.com>"

# Logging — nivel de logs (opcional, default: info)
# Opciones: trace | debug | info | warn | error
LOG_LEVEL="info"
