# ─── Configuración para despliegue local con Docker Compose ──────────────────
# Uso: cp .env.example .env && docker compose up --build
# Todos los valores apuntan a servicios internos del compose — sin dependencias externas.

# PostgreSQL (servicio "postgres" del compose)
DATABASE_URL="postgresql://scrapper:scrapper@postgres:5432/scrapper"

# MongoDB (servicio "mongo" del compose)
MONGODB_URI="mongodb://mongo:27017/scrapper"

# Redis (servicio "redis" del compose)
REDIS_URL="redis://redis:6379"

# SMTP — Mailpit (servicio "mailpit" del compose)
# Ver emails capturados en: http://localhost:8025
SMTP_HOST="mailpit"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Scrapper <noreply@localhost>"

# Logging (trace | debug | info | warn | error)
LOG_LEVEL="info"
